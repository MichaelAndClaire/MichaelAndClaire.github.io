---
import PageHero from '../components/PageHero.astro';
import { wedding } from '../data/wedding';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="FAQ">
  <PageHero
    eyebrow="FAQ"
    title="Answers before the group chat gets powerful."
    copy="Travel notes, mountain logistics, dress code, parking, and the important little wedding-day details."
  />

  <section class="bg-linen py-16 sm:py-20">
    <div class="section-shell max-w-5xl">
      <div class="grid gap-10">
        {wedding.faqs.map((group) => (
          <div>
            <p class="eyebrow">{group.category}</p>
            <div class="mt-5 grid gap-4">
              {group.entries.map((faq) => (
                <details class="rounded-md border border-ink/10 bg-white p-6 shadow-soft">
                  <summary class="cursor-pointer font-display text-2xl font-bold">{faq.question}</summary>
                  <p class="mt-4 leading-7 text-ink/75">{faq.answer}</p>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
