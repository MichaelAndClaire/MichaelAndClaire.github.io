---
interface Props {
  eyebrow: string;
  title: string;
  copy: string;
}

const { eyebrow, title, copy } = Astro.props;
---

<section class="bg-mist py-16 sm:py-20">
  <div class="section-shell">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="mt-4 max-w-3xl font-display text-4xl font-bold leading-tight sm:text-5xl">{title}</h1>
    <p class="mt-5 max-w-2xl text-lg leading-8 text-ink/75">{copy}</p>
  </div>
</section>
