---
import { wedding } from '../data/wedding';

const { accessGate } = wedding;
---

{
  accessGate.enabled && (
    <div
      id="access-gate"
      class="fixed inset-0 z-50 flex min-h-svh items-center justify-center bg-linen px-5 py-10"
      data-invite-hash={accessGate.inviteCodeHash}
      data-storage-key={accessGate.storageKey}
      data-endpoint-storage-key={accessGate.endpointStorageKey}
      data-encrypted-endpoint={accessGate.encryptedRsvpEndpoint}
    >
      <div class="w-full max-w-md rounded-md border border-ink/10 bg-white p-6 shadow-soft sm:p-8">
        <p class="eyebrow">Private celebration</p>
        <h1 class="mt-4 font-display text-4xl font-bold text-ink sm:text-5xl">Michael & Claire</h1>
        <p class="mt-4 leading-7 text-ink/75">
          Enter the invite code from your invitation to view the wedding details.
        </p>
        <form id="access-gate-form" class="mt-6">
          <label class="text-sm font-bold text-ink" for="access-code">Invite code</label>
          <div class="relative mt-2">
            <input
              id="access-code"
              class="input-field mt-0 pr-20"
              name="access-code"
              type="password"
              autocomplete="off"
              required
            />
            <button
              id="access-code-visibility"
              class="focus-ring absolute right-2 top-1/2 min-h-9 -translate-y-1/2 rounded-md px-3 text-sm font-bold text-ink/70 transition hover:bg-mist hover:text-ink"
              type="button"
              aria-controls="access-code"
              aria-pressed="false"
            >
              Show
            </button>
          </div>
          <p id="access-gate-error" class="mt-3 text-sm font-semibold text-coral" role="alert" hidden>
            That code did not match. Check the invitation and try again.
          </p>
          <button class="button-primary mt-5 w-full" type="submit">Unlock Site</button>
        </form>
      </div>
    </div>
  )
}

{
  accessGate.enabled && (
    <script is:inline>
      (() => {
        const initAccessGate = () => {
        const gate = document.getElementById('access-gate');
        const page = document.getElementById('site-content');
        const form = document.getElementById('access-gate-form');
        const input = document.getElementById('access-code');
        const visibilityButton = document.getElementById('access-code-visibility');
        const error = document.getElementById('access-gate-error');

        if (!gate || !page || !form || !input || !visibilityButton || !error) return;

        const expectedHash = gate.dataset.inviteHash;
        const storageKey = gate.dataset.storageKey;
        const endpointStorageKey = gate.dataset.endpointStorageKey;
        const encryptedEndpoint = gate.dataset.encryptedEndpoint;

        const showSite = () => {
          gate.classList.add('hidden');
          page.classList.remove('hidden');
        };

        const encodeUtf8 = (text) => {
          const bytes = [];

          for (let index = 0; index < text.length; index += 1) {
            let codePoint = text.charCodeAt(index);

            if (codePoint >= 0xd800 && codePoint <= 0xdbff && index + 1 < text.length) {
              const next = text.charCodeAt(index + 1);

              if (next >= 0xdc00 && next <= 0xdfff) {
                codePoint = 0x10000 + ((codePoint - 0xd800) << 10) + (next - 0xdc00);
                index += 1;
              }
            }

            if (codePoint < 0x80) {
              bytes.push(codePoint);
            } else if (codePoint < 0x800) {
              bytes.push(0xc0 | (codePoint >> 6), 0x80 | (codePoint & 0x3f));
            } else if (codePoint < 0x10000) {
              bytes.push(
                0xe0 | (codePoint >> 12),
                0x80 | ((codePoint >> 6) & 0x3f),
                0x80 | (codePoint & 0x3f),
              );
            } else {
              bytes.push(
                0xf0 | (codePoint >> 18),
                0x80 | ((codePoint >> 12) & 0x3f),
                0x80 | ((codePoint >> 6) & 0x3f),
                0x80 | (codePoint & 0x3f),
              );
            }
          }

          return new Uint8Array(bytes);
        };

        const rotateRight = (value, shift) => (value >>> shift) | (value << (32 - shift));

        const sha256Fallback = (bytes) => {
          const constants = [
            0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4,
            0xab1c5ed5, 0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe,
            0x9bdc06a7, 0xc19bf174, 0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f,
            0x4a7484aa, 0x5cb0a9dc, 0x76f988da, 0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7,
            0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967, 0x27b70a85, 0x2e1b2138, 0x4d2c6dfc,
            0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85, 0xa2bfe8a1, 0xa81a664b,
            0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070, 0x19a4c116,
            0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
            0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7,
            0xc67178f2,
          ];
          const hash = [
            0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a, 0x510e527f, 0x9b05688c, 0x1f83d9ab,
            0x5be0cd19,
          ];
          const padded = Array.from(bytes);
          const bitLength = padded.length * 8;

          padded.push(0x80);

          while (padded.length % 64 !== 56) {
            padded.push(0);
          }

          for (let shift = 56; shift >= 0; shift -= 8) {
            padded.push((bitLength / Math.pow(2, shift)) & 0xff);
          }

          for (let offset = 0; offset < padded.length; offset += 64) {
            const words = new Array(64);

            for (let index = 0; index < 16; index += 1) {
              const byteIndex = offset + index * 4;
              words[index] =
                ((padded[byteIndex] << 24) |
                  (padded[byteIndex + 1] << 16) |
                  (padded[byteIndex + 2] << 8) |
                  padded[byteIndex + 3]) >>>
                0;
            }

            for (let index = 16; index < 64; index += 1) {
              const s0 =
                rotateRight(words[index - 15], 7) ^
                rotateRight(words[index - 15], 18) ^
                (words[index - 15] >>> 3);
              const s1 =
                rotateRight(words[index - 2], 17) ^
                rotateRight(words[index - 2], 19) ^
                (words[index - 2] >>> 10);
              words[index] = (words[index - 16] + s0 + words[index - 7] + s1) >>> 0;
            }

            let [a, b, c, d, e, f, g, h] = hash;

            for (let index = 0; index < 64; index += 1) {
              const s1 = rotateRight(e, 6) ^ rotateRight(e, 11) ^ rotateRight(e, 25);
              const choice = (e & f) ^ (~e & g);
              const temp1 = (h + s1 + choice + constants[index] + words[index]) >>> 0;
              const s0 = rotateRight(a, 2) ^ rotateRight(a, 13) ^ rotateRight(a, 22);
              const majority = (a & b) ^ (a & c) ^ (b & c);
              const temp2 = (s0 + majority) >>> 0;

              h = g;
              g = f;
              f = e;
              e = (d + temp1) >>> 0;
              d = c;
              c = b;
              b = a;
              a = (temp1 + temp2) >>> 0;
            }

            hash[0] = (hash[0] + a) >>> 0;
            hash[1] = (hash[1] + b) >>> 0;
            hash[2] = (hash[2] + c) >>> 0;
            hash[3] = (hash[3] + d) >>> 0;
            hash[4] = (hash[4] + e) >>> 0;
            hash[5] = (hash[5] + f) >>> 0;
            hash[6] = (hash[6] + g) >>> 0;
            hash[7] = (hash[7] + h) >>> 0;
          }

          return hash.map((value) => value.toString(16).padStart(8, '0')).join('');
        };

        const sha256Hex = async (bytes) => {
          if (window.crypto?.subtle) {
            const digest = await window.crypto.subtle.digest('SHA-256', bytes);

            return Array.from(new Uint8Array(digest))
              .map((byte) => byte.toString(16).padStart(2, '0'))
              .join('');
          }

          return sha256Fallback(bytes);
        };

        const base64ToBytes = (value) => Uint8Array.from(window.atob(value), (char) => char.charCodeAt(0));

        const hexToBytes = (hex) => {
          const bytes = new Uint8Array(hex.length / 2);

          for (let index = 0; index < bytes.length; index += 1) {
            bytes[index] = Number.parseInt(hex.slice(index * 2, index * 2 + 2), 16);
          }

          return bytes;
        };

        const decryptEndpoint = async (code) => {
          const cipherBytes = base64ToBytes(encryptedEndpoint || '');
          const plainBytes = new Uint8Array(cipherBytes.length);
          let offset = 0;
          let counter = 0;

          while (offset < cipherBytes.length) {
            const streamHash = await sha256Hex(encodeUtf8(`${code}:${counter}`));
            const streamBytes = hexToBytes(streamHash);

            for (let index = 0; index < streamBytes.length && offset < cipherBytes.length; index += 1) {
              plainBytes[offset] = cipherBytes[offset] ^ streamBytes[index];
              offset += 1;
            }

            counter += 1;
          }

          return String.fromCharCode(...plainBytes);
        };

        const rememberUnlock = async (code) => {
          const endpoint = await decryptEndpoint(code);

          if (endpointStorageKey) {
            window.localStorage.setItem(endpointStorageKey, endpoint);
          }

          if (storageKey) {
            window.localStorage.setItem(storageKey, 'unlocked');
          }

          window.dispatchEvent(new CustomEvent('access-gate:unlocked', { detail: { endpoint } }));
        };

        if (
          storageKey &&
          window.localStorage.getItem(storageKey) === 'unlocked' &&
          (!endpointStorageKey || window.localStorage.getItem(endpointStorageKey))
        ) {
          showSite();
          return;
        }

        visibilityButton.addEventListener('click', () => {
          const isVisible = input.type === 'text';

          input.type = isVisible ? 'password' : 'text';
          visibilityButton.textContent = isVisible ? 'Show' : 'Hide';
          visibilityButton.setAttribute('aria-pressed', String(!isVisible));
          input.focus();
        });

        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          error.hidden = true;

          const code = input.value.trim();
          const bytes = encodeUtf8(code);
          const hash = await sha256Hex(bytes);

          if (hash === expectedHash) {
            await rememberUnlock(code);
            showSite();
            return;
          }

          input.value = '';
          error.hidden = false;
          input.focus();
        });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initAccessGate, { once: true });
        } else {
          initAccessGate();
        }
      })();
    </script>
  )
}
