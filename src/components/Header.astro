---
import { wedding } from '../data/wedding';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-40 border-b border-ink/10 bg-linen/90 backdrop-blur">
  <nav class="section-shell flex min-h-20 items-center justify-between gap-4" aria-label="Main navigation">
    <a class="font-display text-xl font-bold text-ink no-underline focus-ring rounded-md" href="/">
      {wedding.couple.shortNames}
    </a>

    <div class="hidden items-center gap-1 lg:flex">
      {wedding.navItems.map((item) => {
        const itemPath = item.href.replace(/\/$/, '') || '/';
        const isActive = itemPath === currentPath;
        return (
          <a
            href={item.href}
            class:list={[
            'rounded-md px-2 py-2 text-xs font-bold no-underline transition hover:bg-mist xl:px-3 xl:text-sm',
              isActive ? 'bg-petal text-ink' : 'text-ink/75',
            ]}
            aria-current={isActive ? 'page' : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </div>

    <a class="button-primary hidden lg:inline-flex" href="/rsvp">RSVP</a>

    <details class="group relative lg:hidden">
      <summary class="focus-ring flex min-h-11 cursor-pointer list-none items-center rounded-md border border-ink/20 px-4 py-2 text-sm font-bold">
        Menu
      </summary>
      <div class="absolute right-0 mt-3 w-64 rounded-md border border-ink/10 bg-white p-3 shadow-soft">
        {wedding.navItems.map((item) => (
          <a class="block rounded-md px-3 py-3 text-sm font-bold text-ink no-underline hover:bg-mist" href={item.href}>
            {item.label}
          </a>
        ))}
      </div>
    </details>
  </nav>
</header>
