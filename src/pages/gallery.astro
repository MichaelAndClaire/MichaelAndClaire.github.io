---
import PageHero from '../components/PageHero.astro';
import { wedding } from '../data/wedding';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Gallery">
  <PageHero
    eyebrow="Gallery"
    title="Photos, mountain light, and the good stuff."
    copy={`Huge shout out to ${wedding.gallery.photographer}. We will keep adding photos here as we have them.`}
  />

  <section class="bg-white py-16 sm:py-20">
    <div class="section-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div class="rounded-md bg-mist p-6 shadow-soft sm:p-8">
        <p class="eyebrow">Photo credit</p>
        <h2 class="mt-4 font-display text-3xl font-bold">{wedding.gallery.photographer}</h2>
        <p class="mt-4 leading-7 text-ink/75">{wedding.gallery.credit}</p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {wedding.gallery.images.map((image) => (
          <figure class="overflow-hidden rounded-md bg-linen shadow-soft">
            <img class="aspect-[4/3] w-full object-cover" src={image.src} alt={image.alt} loading="lazy" />
            <figcaption class="p-5 text-sm font-semibold text-ink/70">{image.caption}</figcaption>
          </figure>
        ))}
        <div class="flex min-h-64 items-center justify-center rounded-md border border-dashed border-ink/20 bg-linen p-6 text-center">
          <div>
            <p class="eyebrow">Coming soon</p>
            <p class="mt-3 font-display text-2xl font-bold">More photos after the camera roll catches up.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
