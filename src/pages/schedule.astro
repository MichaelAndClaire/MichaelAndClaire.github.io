---
import PageHero from '../components/PageHero.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Schedule">
  <PageHero
    eyebrow="Wedding day"
    title="Schedule coming soon."
    copy="We are still polishing the timing for the day. Check back here for ceremony, dinner, dancing, and any extra weekend plans."
  />

  <section class="bg-linen py-16 sm:py-20">
    <div class="section-shell max-w-3xl">
      <div class="rounded-md bg-white p-6 text-center shadow-soft sm:p-10">
        <p class="eyebrow">Details in progress</p>
        <h2 class="mt-4 font-display text-4xl font-bold">We will share the plan once it is official.</h2>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-ink/75">
          For now, keep the date open and plan for a mountain celebration with ceremony, food, dancing, and excellent
          company. The final timeline will live here before invitations go out.
        </p>
      </div>
    </div>
  </section>
</SiteLayout>
