---
import PageHero from '../components/PageHero.astro';
import { wedding } from '../data/wedding';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Venue & Travel">
  <PageHero
    eyebrow="Getting there"
    title="Venue, hotel, parking, and travel notes."
    copy="This page is the landing zone for anything that helps guests get to the celebration without too much detective work."
  />

  <section class="bg-white py-16 sm:py-20">
    <div class="section-shell grid gap-10 lg:grid-cols-[1fr_1fr]">
      <div>
        <p class="eyebrow">Venue</p>
        <h2 class="mt-4 font-display text-4xl font-bold">{wedding.location.venueName}</h2>
        <p class="mt-4 text-lg leading-8 text-ink/75">{wedding.location.address}</p>
        <a class="button-primary mt-8" href={wedding.location.mapUrl}>Open Map</a>
      </div>

      <div class="rounded-md bg-mist p-6 sm:p-8">
        <p class="eyebrow">Hotel</p>
        <h2 class="mt-4 font-display text-3xl font-bold">{wedding.travel.hotel.name}</h2>
        <p class="mt-4 leading-7 text-ink/75">{wedding.travel.hotel.detail}</p>
        <a class="button-secondary mt-8" href={wedding.travel.hotel.bookingUrl}>Booking Link</a>
      </div>
    </div>
  </section>

  <section class="bg-linen py-16 sm:py-20">
    <div class="section-shell grid gap-4 md:grid-cols-3">
      <article class="rounded-md bg-white p-6 shadow-soft">
        <h2 class="font-display text-2xl font-bold">Airport</h2>
        <p class="mt-3 leading-7 text-ink/75">{wedding.travel.airport}</p>
      </article>
      <article class="rounded-md bg-white p-6 shadow-soft">
        <h2 class="font-display text-2xl font-bold">Parking</h2>
        <p class="mt-3 leading-7 text-ink/75">{wedding.travel.parking}</p>
      </article>
      <article class="rounded-md bg-white p-6 shadow-soft">
        <h2 class="font-display text-2xl font-bold">Transportation</h2>
        <p class="mt-3 leading-7 text-ink/75">{wedding.travel.transportation}</p>
      </article>
    </div>
  </section>
</SiteLayout>
