---
import PageHero from '../components/PageHero.astro';
import { wedding } from '../data/wedding';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="RSVP">
  <PageHero
    eyebrow="RSVP"
    title="Tell us if you'll be there."
    copy="or if you won't :[."
  />

  <section class="bg-linen py-16 sm:py-20">
    <div class="section-shell max-w-4xl">
      <div class="rounded-md bg-white p-6 shadow-soft sm:p-8">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="eyebrow">RSVP form</p>
          </div>
          <a
            id="rsvp-open-link"
            class="button-primary pointer-events-none opacity-60"
            data-endpoint-storage-key={wedding.accessGate.endpointStorageKey}
            aria-disabled="true"
          >
            Open RSVP Form
          </a>
        </div>

        <p id="rsvp-endpoint-status" class="mt-6 text-sm font-semibold text-coral" role="alert">
          Unlock the site with your invite code to load the RSVP form.
        </p>

        <div class="mt-8 overflow-hidden rounded-md border border-ink/10 bg-linen">
          <iframe
            id="rsvp-frame"
            class="hidden h-[760px] w-full bg-white"
            title="Michael and Claire RSVP"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const initRsvpEndpoint = () => {
        const link = document.getElementById('rsvp-open-link');
        const frame = document.getElementById('rsvp-frame');
        const status = document.getElementById('rsvp-endpoint-status');

        if (!link || !frame || !status) return;

        const endpointStorageKey = link.dataset.endpointStorageKey;

        const setEndpoint = (endpoint) => {
          if (!endpoint) return;

          link.setAttribute('href', endpoint);
          link.setAttribute('target', '_blank');
          link.setAttribute('rel', 'noreferrer');
          link.setAttribute('aria-disabled', 'false');
          link.classList.remove('pointer-events-none', 'opacity-60');
          frame.setAttribute('src', endpoint);
          frame.classList.remove('hidden');
          status.hidden = true;
        };

        setEndpoint(endpointStorageKey ? window.localStorage.getItem(endpointStorageKey) : '');

        window.addEventListener('access-gate:unlocked', (event) => {
          setEndpoint(event.detail?.endpoint);
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRsvpEndpoint, { once: true });
      } else {
        initRsvpEndpoint();
      }
    })();
  </script>
</SiteLayout>
