---
import PageHero from '../components/PageHero.astro';
import { wedding } from '../data/wedding';
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="RSVP">
  <PageHero
    eyebrow="RSVP"
    title="Tell us if you'll be there."
    copy="Use the invite code from your invitation. It is not a password; it just helps us match responses to our guest list."
  />

  <section class="bg-linen py-16 sm:py-20">
    <div class="section-shell max-w-3xl">
      <form
        id="rsvp-form"
        class="rounded-md bg-white p-6 shadow-soft sm:p-8"
        method="POST"
        data-endpoint-storage-key={wedding.accessGate.endpointStorageKey}
      >
        <input type="hidden" name="_subject" value="Wedding RSVP" />

        <div class="grid gap-6 md:grid-cols-2">
          <label class="block font-bold">
            Name
            <input class="input-field" type="text" name="name" autocomplete="name" required />
          </label>

          <label class="block font-bold">
            Email
            <input class="input-field" type="email" name="email" autocomplete="email" required />
          </label>

          <label class="block font-bold">
            Invite code
            <input class="input-field" type="text" name="invite_code" autocomplete="off" required />
          </label>

          <label class="block font-bold">
            Attending?
            <select class="input-field" name="attending" required>
              <option value="">Choose one</option>
              <option value="yes">Yes, happily</option>
              <option value="no">Sadly, no</option>
            </select>
          </label>

          <label class="block font-bold">
            Guest count
            <input class="input-field" type="number" name="guest_count" min="1" max="8" value="1" required />
          </label>

          <label class="block font-bold">
            Meal preference
            <select class="input-field" name="meal_preference">
              {wedding.mealChoices.map((meal) => <option value={meal}>{meal}</option>)}
            </select>
          </label>
        </div>

        <label class="mt-6 block font-bold">
          Allergies or dietary notes
          <textarea class="input-field min-h-28" name="allergies"></textarea>
        </label>

        <label class="mt-6 block font-bold">
          Notes
          <textarea class="input-field min-h-32" name="notes"></textarea>
        </label>

        <p id="rsvp-endpoint-status" class="mt-6 text-sm font-semibold text-coral" role="alert" hidden>
          Unlock the site with your invite code before submitting your RSVP.
        </p>

        <button id="rsvp-submit" class="button-primary mt-8 w-full disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto" type="submit" disabled>
          Submit RSVP
        </button>
      </form>
    </div>
  </section>

  <script is:inline>
    (() => {
      const initRsvpEndpoint = () => {
        const form = document.getElementById('rsvp-form');
        const submit = document.getElementById('rsvp-submit');
        const status = document.getElementById('rsvp-endpoint-status');

        if (!form || !submit || !status) return;

        const endpointStorageKey = form.dataset.endpointStorageKey;

        const setEndpoint = (endpoint) => {
          if (!endpoint) return;

          form.setAttribute('action', endpoint);
          submit.disabled = false;
          status.hidden = true;
        };

        setEndpoint(endpointStorageKey ? window.localStorage.getItem(endpointStorageKey) : '');

        window.addEventListener('access-gate:unlocked', (event) => {
          setEndpoint(event.detail?.endpoint);
        });

        form.addEventListener('submit', (event) => {
          if (!form.getAttribute('action')) {
            event.preventDefault();
            submit.disabled = true;
            status.hidden = false;
          }
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRsvpEndpoint, { once: true });
      } else {
        initRsvpEndpoint();
      }
    })();
  </script>
</SiteLayout>
